---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Stories | ${SITE_TITLE}`}
			description="Narrative nonfiction grounded in real historical events — told with the depth and tension of lived experience."
		/>
		<style>
			main {
				width: 960px;
			}
			.page-header {
				padding: 3em 0 2em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2.5em;
			}
			.page-header h1 {
				font-size: 2.2em;
				margin-bottom: 0.4em;
			}
			.page-header p {
				color: rgb(var(--gray));
				font-size: 1em;
				margin: 0;
				max-width: 560px;
				font-style: italic;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1.25rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 0.5rem;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 1.9rem;
			}
			ul li img {
				margin-bottom: 0.75rem;
				border-radius: 8px;
			}
			ul li a {
				display: block;
			}
			.card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 1.5em;
				background: white;
				transition: box-shadow 0.2s ease, border-color 0.2s ease;
				height: 100%;
				box-sizing: border-box;
				display: flex;
				flex-direction: column;
			}
			.card:hover {
				box-shadow: var(--box-shadow);
				border-color: rgb(var(--gray));
			}
			ul li:first-child .card {
				padding: 0;
				border: none;
				background: transparent;
				border-radius: 0;
			}
			ul li:first-child .card:hover {
				box-shadow: none;
				border-color: transparent;
			}
			.title {
				margin: 0 0 0.4em;
				color: rgb(var(--black));
				line-height: 1.2;
				font-size: 1.15rem;
			}
			ul li:first-child .title {
				margin-top: 0.5em;
			}
			.date {
				margin: 0 0 0.6em;
				color: rgb(var(--gray));
				font-size: 0.82em;
				font-family: "Atkinson", sans-serif;
				letter-spacing: 0.02em;
			}
			.description {
				margin: 0 0 1em;
				color: rgb(var(--gray-dark));
				font-size: 0.9em;
				line-height: 1.6;
				flex-grow: 1;
			}
			.read-more {
				font-size: 0.82em;
				font-family: "Atkinson", sans-serif;
				font-weight: 700;
				color: var(--accent);
				letter-spacing: 0.04em;
				display: inline-block;
				margin-top: auto;
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			ul li a:hover .read-more {
				color: var(--accent-dark);
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 1rem;
				}
				ul li {
					width: 100%;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Stories</h1>
				<p>Real history. Narrative depth. Written for people who take their industry seriously.</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<div class="card">
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
											{post.data.author && <span> &middot; {post.data.author}</span>}
										</p>
										{post.data.description && (
											<p class="description">{post.data.description}</p>
										)}
										<span class="read-more">Read more &rarr;</span>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
