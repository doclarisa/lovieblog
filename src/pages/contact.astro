---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Get in touch to discuss a project or partnership with Lovie Project Studio."
		/>
		<style>
			main {
				max-width: 640px;
			}
			.page-header {
				padding: 2.5em 0 2em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2.5em;
			}
			.page-header h1 {
				font-size: 2.4em;
				margin-bottom: 0.3em;
			}
			.intro {
				color: rgb(var(--gray));
				font-size: 1.05em;
				margin: 0;
				font-style: italic;
				line-height: 1.6;
			}
			.contact-block {
				margin-top: 2em;
			}
			.contact-block p {
				font-size: 1em;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
				margin-bottom: 1.25em;
			}
			.contact-email {
				display: inline-block;
				font-family: "Atkinson", sans-serif;
				font-size: 1.05em;
				font-weight: 700;
				color: var(--accent);
				text-decoration: none;
				border-bottom: 2px solid var(--accent);
				padding-bottom: 2px;
				transition: color 0.15s ease, border-color 0.15s ease;
			}
			.contact-email:hover {
				color: var(--accent-dark);
				border-color: var(--accent-dark);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Contact</h1>
				<p class="intro">To discuss a project or partnership, reach out directly.</p>
			</div>
			<div class="contact-block">
				<p>
					We work with companies of all sizes, from single-project engagements to
					ongoing content partnerships. Whether you have a specific brief or just a
					question about what we do, we read everything.
				</p>
				<a href="mailto:info@lovieproject.com" class="contact-email">info@lovieproject.com</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
