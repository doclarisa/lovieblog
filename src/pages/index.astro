---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

function extractFirstImageUrl(body: string): string | null {
	const match = body.match(/!\[.*?\]\((.+?)\)/);
	return match ? match[1] : null;
}

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6)
	.map((post) => ({
		...post,
		bodyThumb: !post.data.heroImage ? extractFirstImageUrl(post.body ?? '') : null,
	}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 2.25em 1em 2em;
				text-align: left;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2.5em;
				max-width: 700px;
			}
			.hero .label {
				font-family: "Atkinson", sans-serif;
				font-size: 0.75em;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent);
				font-weight: 700;
				margin-bottom: 0.75em;
				display: block;
			}
			.hero h1 {
				font-size: 3.2em;
				margin-bottom: 0.4em;
				line-height: 1.05;
				font-family: Georgia, "Times New Roman", serif;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.hero p {
				color: rgb(var(--gray));
				font-size: 1.05em;
				margin: 0 0 1.5em;
				line-height: 1.7;
				font-style: italic;
			}
			.hero-cta {
				display: inline-block;
				background: var(--accent);
				color: white;
				text-decoration: none;
				padding: 0.6em 1.4em;
				border-radius: 4px;
				font-family: "Atkinson", sans-serif;
				font-size: 0.85em;
				font-weight: 700;
				letter-spacing: 0.04em;
				transition: background 0.15s ease;
			}
			.hero-cta:hover {
				background: var(--accent-dark);
				color: white;
			}
			main {
				width: 960px;
			}
			.recent-posts {
				margin-bottom: 2em;
			}
			.section-label {
				font-family: "Atkinson", sans-serif;
				font-size: 0.72em;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				font-weight: 700;
				margin-bottom: 1.5em;
				padding-bottom: 0.75em;
				border-bottom: 1px solid rgb(var(--gray-light));
				display: block;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 0.5rem;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 1.9rem;
			}
			ul li img {
				margin-bottom: 0.75rem;
				border-radius: 8px;
			}
			ul li a {
				display: block;
			}
			.card {
				padding: 0;
			}
			.title {
				margin: 0 0 0.35em;
				color: rgb(var(--black));
				line-height: 1.15;
				font-size: 1.15rem;
				font-family: Georgia, "Times New Roman", serif;
				font-weight: 700;
				letter-spacing: -0.01em;
			}
			.date {
				margin: 0 0 0.5em;
				color: rgb(var(--gray));
				font-size: 0.82em;
				font-family: "Atkinson", sans-serif;
			}
			.description {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.88em;
				line-height: 1.55;
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.card-thumb {
				width: 100%;
				height: 220px;
				object-fit: cover;
				border-radius: 8px;
				margin-bottom: 0.75rem;
				display: block;
			}
			ul li:first-child .card-thumb {
				height: 360px;
			}
			.all-posts {
				margin-top: 2.5em;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.all-posts a {
				color: var(--accent);
				text-decoration: none;
				font-family: "Atkinson", sans-serif;
				font-weight: 700;
				font-size: 0.9em;
				letter-spacing: 0.03em;
			}
			.all-posts a:hover {
				color: var(--accent-dark);
				text-decoration: underline;
			}
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2em;
				}
				ul {
					gap: 1rem;
				}
				ul li {
					width: 100%;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<span class="label">Lovie Project Studio</span>
				<h1>History as it actually happened</h1>
				<p>
					Real events. Real stakes. Written with the narrative depth and tension of Erik Larson-style
					storytelling — for businesses that want content worth reading.
				</p>
				<a href="/blog" class="hero-cta">Read the stories &rarr;</a>
			</div>
			<section class="recent-posts">
				<span class="section-label">Recent Stories</span>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage ? (
										<Image width={720} height={360} src={post.data.heroImage} alt="" class="card-thumb" />
									) : post.bodyThumb ? (
										<img src={post.bodyThumb} alt="" class="card-thumb" />
									) : null}
									<div class="card">
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
											{post.data.author && <span> &middot; {post.data.author}</span>}
										</p>
										{post.data.description && (
											<p class="description">{post.data.description}</p>
										)}
									</div>
								</a>
							</li>
						))
					}
				</ul>
				<div class="all-posts">
					<a href="/blog/">View all stories &rarr;</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
