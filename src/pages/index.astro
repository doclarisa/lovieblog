---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 4em 1em 2em;
				text-align: center;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.4em;
			}
			.hero p {
				max-width: 600px;
				margin: 0 auto;
				color: rgb(var(--gray));
				font-size: 1.1em;
			}
			main {
				width: 960px;
			}
			.recent-posts h2 {
				margin-bottom: 1.5em;
				font-size: 1.4em;
				color: rgb(var(--gray-dark));
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0.4em 0 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.description {
				margin: 0.4em 0 0;
				color: rgb(var(--gray-dark));
				font-size: 0.9em;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.all-posts {
				margin-top: 2em;
				text-align: center;
			}
			.all-posts a {
				color: rgb(var(--accent));
				text-decoration: none;
				font-weight: 600;
			}
			.all-posts a:hover {
				text-decoration: underline;
			}
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 1.8em;
				}
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>The Lovie Project</h1>
				<p>{SITE_DESCRIPTION}</p>
			</div>
			<section class="recent-posts">
				<h2>Recent Stories</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
										{post.data.author && <span> &middot; {post.data.author}</span>}
									</p>
									{post.data.description && (
										<p class="description">{post.data.description}</p>
									)}
								</a>
							</li>
						))
					}
				</ul>
				<div class="all-posts">
					<a href="/blog/">View all stories &rarr;</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
