---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 0;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 0;
				box-shadow: none;
				max-height: 480px;
				width: 100%;
				object-fit: cover;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em 1em;
				color: rgb(var(--gray-dark));
			}
			.article-header {
				margin-bottom: 2em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.article-header h1 {
				font-size: 2.4em;
				line-height: 1.15;
				margin: 0 0 0.5em;
				color: rgb(var(--black));
			}
			.meta {
				display: flex;
				align-items: center;
				gap: 0.75em;
				flex-wrap: wrap;
				font-size: 0.85em;
				font-family: "Atkinson", sans-serif;
				color: rgb(var(--gray));
			}
			.meta .author {
				font-weight: 700;
				color: rgb(var(--gray-dark));
			}
			.meta .separator {
				color: rgb(var(--gray-light));
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-top: 0.5em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1280} height={480} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="article-header">
						<h1>{title}</h1>
						<div class="meta">
							{author && <span class="author">{author}</span>}
							{author && <span class="separator">&middot;</span>}
							<span><FormattedDate date={pubDate} /></span>
							{
								updatedDate && (
									<span class="last-updated-on">
										Updated <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</div>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
