---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="masthead">
		<a href="/" class="brand">{SITE_TITLE}</a>
		<p class="tagline">Turning historical events into unforgettable content</p>
	</div>
	<nav>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Stories</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		background: rgb(22, 22, 28);
		border-bottom: 3px solid #b5470a;
	}
	.masthead {
		max-width: 960px;
		margin: 0 auto;
		padding: 1.5em 1em 1em;
		display: flex;
		align-items: baseline;
		gap: 1.5em;
	}
	.brand {
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.6em;
		font-weight: 700;
		color: #fff9f5;
		text-decoration: none;
		letter-spacing: -0.01em;
		line-height: 1;
		white-space: nowrap;
	}
	.brand:hover {
		color: #fde8dc;
	}
	.tagline {
		font-family: Georgia, "Times New Roman", serif;
		font-size: 0.8em;
		color: rgba(255, 249, 245, 0.5);
		margin: 0;
		font-style: italic;
		line-height: 1;
	}
	nav {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1em;
		border-top: 1px solid rgba(255, 249, 245, 0.08);
	}
	.internal-links {
		display: flex;
		gap: 0;
	}
	nav :global(a) {
		padding: 0.6em 1em 0.6em 0;
		color: rgba(255, 249, 245, 0.75);
		border-bottom: 3px solid transparent;
		margin-bottom: -3px;
		text-decoration: none;
		font-size: 0.85em;
		font-family: "Atkinson", sans-serif;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	nav :global(a:hover) {
		color: #fff9f5;
	}
	nav :global(a.active) {
		color: #b5470a;
		border-bottom-color: #b5470a;
	}
	@media (max-width: 720px) {
		.masthead {
			flex-direction: column;
			gap: 0.3em;
			padding: 1em 1em 0.75em;
		}
		.brand {
			font-size: 1.3em;
		}
		.tagline {
			font-size: 0.75em;
		}
	}
</style>
